{"componentChunkName":"component---src-templates-boattemplate-jsx","path":"/boat/1318","result":{"pageContext":{"boat":{"oga_no":1318,"id":"64c6ee03-14b2-45ef-ad9a-a7d1cde8a546","name":"Alberta","previous_names":null,"year":1885,"year_is_approximate":false,"public":true,"place_built":"Brightlingsea","home_port":"Brightlingsea","home_country":"GBR","ssr":null,"sail_number":null,"nhsr":null,"nsbr":null,"fishing_number":null,"callsign":"","mssi":null,"full_description":"<p>Alberta is thought to be the first smack to be fitted with an engine. Built by Aldous of Brightlingsea, as a cutter-rigged oyster smack, her fishing number is CK318, registered in Colchester. She is listed on the National Historic Ships UK register, visit her website from the link above.</p>\r\n\r\n<p><a href=\"https://www.flickr.com/photos/colmolaoi/with/14394546619\" target=\"_blank\">Visit Colm&#39;s photostream on Flickr</a> for more photos of the East Coast Race, 2014.</p>","image_key":"zPG8WJ","uk_part1":null,"spar_material":null,"constructionMaterialByConstructionMaterial":{"name":"wood"},"constructionMethodByConstructionMethod":{"name":"unknown"},"construction_details":"Carvel Pine on Oak Frames","designClassByDesignClass":null,"designerByDesigner":{"name":"Aldous"},"draft":1.396,"generic_type":"Smack","handicap_data":null,"hull_form":"long keel deep forefoot","keel_laid":null,"launched":null,"length_on_deck":13.5636,"mainsail_type":"gaff","rigTypeByRigType":{"name":"Cutter"},"sail_type":{"name":"gaff"},"short_description":"Alberta was built in 1885 by Aldous of Brightlingsea. Totally rebuilt at Barry Tester's yard at Hollowshore, 2002 - 2004, she is one of the fastest smacks sailing today.","updated_at":"2020-12-06T19:14:38.194223+00:00","website":"http://www.nationalhistoricships.org.uk/register/746/alberta","genericTypeByGenericType":{"name":"Smack"},"builderByBuilder":{"name":"Aldous Ltd.","notes":null},"beam":3.5814,"air_draft":null,"reference":null,"for_sale_state":{"text":"not_for_sale