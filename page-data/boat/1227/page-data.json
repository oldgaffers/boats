{"componentChunkName":"component---src-templates-boattemplate-jsx","path":"/boat/1227","result":{"pageContext":{"boat":{"oga_no":1227,"id":"a986eec8-5e01-4f06-99fd-66aa1da7987e","name":"Francesca","previous_names":null,"year":1970,"year_is_approximate":false,"public":true,"place_built":"Hull unknown fitted out Paglesham","home_port":"","home_country":"GBR","ssr":"42633","sail_number":"F C","nhsr":null,"nsbr":null,"fishing_number":null,"callsign":"","mssi":null,"full_description":"<p>Hull believed to be a Canadian design with 3 keels and a Bermudan rig. The Builder of the hull is unknown. Frank Graves fitted out the cabin and gave her a gaff rig and engine in early 1970's at Paglesham. Twin keels were removed in 1979, a topmast added and bowsprit lengthened. In need of a re-build 15.03.15.</p><p>Due to illness the owner was not able to rebuild, and local pressure from the Panglesham Village Trust led to her breakup in 2019. The mast is to be re-used as the mizzen mast for the lugger &quot;Lyonesse&quot; of Mousehole.</p>","image_key":null,"uk_part1":null,"spar_material":null,"constructionMaterialByConstructionMaterial":{"name":"wood"},"constructionMethodByConstructionMethod":{"name":"unknown"},"construction_details":"Mahogany Hard Chine Double skin","designClassByDesignClass":null,"designerByDesigner":{"name":"Unknown"},"draft":1.1582,"generic_type":"Yacht","handicap_data":{"main":{"foot":15.15,"head":10.65,"luff":9.25},"topsail":{"luff":15,"perpendicular":7},"length_overall":7.9248,"calculated_thcf":0.884,"fore_triangle_base":5.1816,"length_on_waterline":7.1384,"fore_triangle_height":6.3398},"hull_form":"long keel deep forefoot","keel_laid":null,"launched":null,"length_on_deck":7.9248,"mainsail_type":"gaff","rigTypeByRigType":{"name":"Cutter"},"sail_type":{"name":"gaff"},"short_description":"","updated_at":"2020-12-06T19:14:38.194223+00:00","website":"","genericTypeByGenericType":{"name":"Yacht"},"builderByBuilder":{"name":"F. Graves","notes":null},"beam":2.987,"air